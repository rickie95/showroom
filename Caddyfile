:80 {
    # Root dei file statici della webapp
    root * /usr/share/caddy

    # Gestione delle richieste OPTIONS (CORS preflight) per TUTTI i percorsi
    @options {
        method OPTIONS
    }
    handle @options {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Max-Age "3600"
        header Access-Control-Expose-Headers "Content-Length"
        header Access-Control-Allow-Headers "*"
        header Access-Control-Allow-Methods "*"
        respond "" 200
    }

    # 1. SPLIT: Richieste che iniziano con /api
    # Vengono inoltrate al tuo server backend
    handle /api/* {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Max-Age "3600"
        header Access-Control-Expose-Headers "Content-Length"
        header Access-Control-Allow-Headers "*"
        header Access-Control-Allow-Methods "*"

        uri strip_prefix /api

        reverse_proxy http://100.98.146.106:3903 {
            header_up X-Forwarded-For {remote_host}
            header_up Host {host}
        }
    }

    # 2. SPLIT: Tutto il resto serve la Webapp Vite
    handle {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Max-Age "3600"
        header Access-Control-Expose-Headers "Content-Length"
        header Access-Control-Allow-Headers "*"
        header Access-Control-Allow-Methods "*"

        # Cerca il file richiesto. Se non esiste (es. route di React/Vue/Svelte),
        # rimanda a index.html per far gestire il routing al frontend.
        try_files {path} /index.html
        file_server
    }
}
